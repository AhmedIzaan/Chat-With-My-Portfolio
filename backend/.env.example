# Required Configuration
GOOGLE_API_KEY=your-gemini-api-key-here

# CORS Configuration (comma-separated origins)
# Use * for development, specific domains for production
ALLOWED_ORIGINS=*

# File Paths
CHROMA_DB_PATH=/tmp/chroma_db
RESUME_FILE_PATH=/app/data/resume.pdf

# Gemini Models (free tier)
EMBEDDING_MODEL=models/gemini-embedding-001
CHAT_MODEL=gemini-2.5-flash

# Chat Configuration
TEMPERATURE=0.3
MAX_TOKENS=1000

# Text Processing
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Note: For production on Render, set these as environment variables in the dashboard
# The resume.pdf file should be committed to the repository in the data/ folder
